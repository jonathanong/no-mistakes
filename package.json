{
  "name": "no-mistakes-monorepo",
  "version": "0.26.0",
  "private": true,
  "description": "Deterministic AST-based codebase intelligence for humans and AI agents",
  "homepage": "https://github.com/jonathanong/no-mistakes#readme",
  "bugs": {
    "url": "https://github.com/jonathanong/no-mistakes/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jonathanong/no-mistakes.git"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:js": "npm --workspaces --if-present run build",
    "test": "vitest run --coverage",
    "test:ci": "vitest run --coverage --reporter=dot --reporter=github-actions",
    "fmt:js": "oxfmt --write packages/ vitest.config.js",
    "fmt:js:check": "oxfmt --check packages/ vitest.config.js",
    "lint:js": "oxlint packages/ vitest.config.js",
    "lint:spell": "cspell lint README.md \"docs/**/*.md\" \"packages/no-mistakes/README.md\" \"packages/eslint-plugin-no-mistakes/README.md\" cspell.config.yaml package.json --no-progress --no-gitignore --show-suggestions --no-must-find-files",
    "pack:check": "npm --workspaces pack --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cspell": "^10.0.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  }
}
