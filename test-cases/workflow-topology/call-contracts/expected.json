      "target": "./.github/workflows/callee.yml",
      "local": true,
      "bindings": {
        "inputs": {
          "message": "hi"
        },
        "secrets": {
          "mode": "explicit",
          "values": {
            "token": "${{ secrets.TOKEN }}"
          }
        }
