      "key": "unknown-input",
      "kind": "job",
      "steps": []
    },
    {
      "id": ".github/workflows/caller.yml#unknown-secret",
      "workflowId": ".github/workflows/caller.yml",
      "key": "unknown-secret",
      "kind": "job",
      "steps": []
    }
  ],
  "edges": [
    {
      "kind": "calls",
      "from": ".github/workflows/caller.yml#expression-input",
      "target": "./.github/workflows/callee.yml",
      "local": true,
      "bindings": {
        "inputs": {
          "flag": "${{ vars.SOME_FLAG }}",
          "message": "hi"
        },
        "secrets": {
          "mode": "explicit",
          "values": {
