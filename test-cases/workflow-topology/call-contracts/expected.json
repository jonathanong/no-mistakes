      "to": ".github/workflows/callee.yml"
    },
    {
      "kind": "calls",
      "from": ".github/workflows/caller.yml#missing-secret",
      "target": "./.github/workflows/callee.yml",
      "local": true,
      "bindings": {
        "inputs": {
          "message": "hi"
        },
        "secrets": {
          "mode": "explicit",
          "values": {}
        }
      },
      "to": ".github/workflows/callee.yml"
    },
    {
