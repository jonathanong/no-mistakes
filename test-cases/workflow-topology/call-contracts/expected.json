      "target": "./.github/workflows/callee.yml",
      "local": true,
      "bindings": {
        "inputs": {
          "extra": "nope",
          "message": "hi"
        },
        "secrets": {
          "mode": "explicit",
          "values": {
            "token": "${{ secrets.TOKEN }}"
          }
        }
      },
      "to": ".github/workflows/callee.yml"
    },
    {
      "kind": "calls",
      "from": ".github/workflows/caller.yml#unknown-secret",
      "target": "./.github/workflows/callee.yml",
      "local": true,
      "bindings": {
        "inputs": {
          "message": "hi"
        },
        "secrets": {
          "mode": "explicit",
          "values": {
            "bogus": "${{ secrets.BOGUS }}",
            "token": "${{ secrets.TOKEN }}"
          }
        }
      },
      "to": ".github/workflows/callee.yml"
    },
    {
      "kind": "needs",
      "from": ".github/workflows/caller.yml#happy",
      "to": ".github/workflows/caller.yml#consumer"
    }
