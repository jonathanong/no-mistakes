{
  "schemaVersion": 1,
  "workflows": [
    {
      "id": ".github/workflows/callee.yml",
      "path": ".github/workflows/callee.yml",
      "name": "Callee",
      "callable": true,
      "workflowCall": {
        "inputs": {
          "flag": {
            "type": "boolean",
            "required": false,
            "default": false
          },
          "message": {
            "type": "string",
            "required": true
          }
        },
        "secrets": {
          "token": {
            "required": true
          }
        },
        "outputs": {
          "result": {
            "value": "${{ jobs.echo.outputs.result }}"
          }
        }
      },
      "triggers": [
        {
          "event": "workflow_call",
          "config": {
            "inputs": {
              "message": {
                "type": "string",
                "required": true
              },
              "flag": {
                "type": "boolean",
                "required": false,
                "default": false
              }
            },
            "secrets": {
              "token": {
                "required": true
              }
            },
            "outputs": {
              "result": {
                "value": "${{ jobs.echo.outputs.result }}"
              }
            }
          }
        }
      ],
      "jobIds": [
        ".github/workflows/callee.yml#echo"
      ]
    },
    {
      "id": ".github/workflows/caller.yml",
      "path": ".github/workflows/caller.yml",
      "name": "Caller",
      "callable": false,
      "triggers": [
        {
          "event": "push"
        }
      ],
      "jobIds": [
        ".github/workflows/caller.yml#consumer",
        ".github/workflows/caller.yml#expression-input",
        ".github/workflows/caller.yml#happy",
        ".github/workflows/caller.yml#inherited-secrets",
        ".github/workflows/caller.yml#missing-input",
        ".github/workflows/caller.yml#missing-secret",
        ".github/workflows/caller.yml#type-mismatch",
        ".github/workflows/caller.yml#unknown-input",
        ".github/workflows/caller.yml#unknown-secret"
      ]
    }
  ],
  "jobs": [
    {
      "id": ".github/workflows/callee.yml#echo",
      "workflowId": ".github/workflows/callee.yml",
      "key": "echo",
      "kind": "job",
      "steps": [
        {
          "index": 0,
          "kind": "run",
          "id": "set"
        }
      ]
    },
    {
      "id": ".github/workflows/caller.yml#consumer",
      "workflowId": ".github/workflows/caller.yml",
      "key": "consumer",
      "kind": "job",
      "condition": "needs.happy.outputs.result == 'ok'",
      "steps": [
        {
          "index": 0,
          "kind": "run"
        }
      ]
    },
    {
      "id": ".github/workflows/caller.yml#expression-input",
      "workflowId": ".github/workflows/caller.yml",
      "key": "expression-input",
      "kind": "job",
      "steps": []
    },
    {
      "id": ".github/workflows/caller.yml#happy",
      "workflowId": ".github/workflows/caller.yml",
      "key": "happy",
      "kind": "job",
      "steps": []
    },
    {
      "id": ".github/workflows/caller.yml#inherited-secrets",
      "workflowId": ".github/workflows/caller.yml",
      "key": "inherited-secrets",
      "kind": "job",
      "steps": []
    },
    {
