#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
no-mistakes-rust-no-inline-tests

Forbid inline #[cfg(test)] mod ... { ... } blocks in Rust source files.

Usage:
  no-mistakes-rust-no-inline-tests <src_dir> [<src_dir>...]
  no-mistakes-rust-no-inline-tests --help

Requires:
  rg with PCRE2 support

Examples:
  no-mistakes-rust-no-inline-tests crates/no-mistakes/src
  no-mistakes-rust-no-inline-tests crates/*/src
USAGE
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

if [ "$#" -lt 1 ]; then
  usage >&2
  exit 2
fi

if ! command -v rg >/dev/null 2>&1; then
  echo "Error: rg (ripgrep) is required." >&2
  echo "  macOS: brew install ripgrep" >&2
  echo "  Linux: apt-get install ripgrep" >&2
  exit 1
fi

set +e
rg_stdout=$(rg -n -U --pcre2 -t rust \
  '#\s*\[\s*cfg\s*\(\s*test\s*\)\s*\]\s*(?:(?:#\s*\[[^\]]*\]|//[^\n]*|/\*[\s\S]*?\*/)\s*)*(?:pub(?:\([^)]*\))?\s+)?mod\s+(?:r#)?\w+\s*\{' \
  "$@" 2>&1)
rg_exit=$?
set -e

if [ "$rg_exit" -ge 2 ]; then
  echo "Error: rg failed with exit code $rg_exit" >&2
  echo "$rg_stdout" >&2
  exit 1
fi

if [ "$rg_exit" -eq 0 ]; then
  echo "$rg_stdout"
  echo
  echo "Inline #[cfg(test)] mod ... { ... } blocks are not allowed."
  echo "Use an out-of-line test module instead:"
  echo
  echo "    #[cfg(test)]"
  echo "    mod tests;"
  echo
  echo "and put the tests in src/<module>/tests.rs or src/<module>/tests/mod.rs."
  exit 1
fi

echo "No inline #[cfg(test)] mod blocks found."
